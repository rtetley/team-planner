# TeamTree server — environment variables
# Copy this file to <server-dir>/.env on the VM and fill in the values.
# Never commit the real .env file.

# Port the Node.js server listens on (must match --api-port in deploy.sh)
PORT=3001

# Valkey / Redis connection URL
VALKEY_URL=redis://127.0.0.1:6379

# GitLab OAuth (optional — leave blank to disable GitLab sign-in)
GITLAB_URL=https://gitlab.com
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=https://your-domain/api/auth/gitlab/callback

# URL the server redirects back to after OAuth (your frontend origin)
FRONTEND_URL=https://your-domain
