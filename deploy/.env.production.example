# TeamTree — production environment
# Copy to <server-dir>/.env.production on the VM and fill in all values.
# Never commit this file with real secrets.

NODE_ENV=production

# Port the Node.js server listens on (must match --api-port in deploy.sh)
PORT=3001

# Valkey / Redis connection URL
VALKEY_URL=redis://127.0.0.1:6379

# GitLab OAuth — fill in to enable GitLab sign-in
GITLAB_URL=https://gitlab.com
GITLAB_CLIENT_ID=your-gitlab-application-id
GITLAB_CLIENT_SECRET=your-gitlab-application-secret
GITLAB_REDIRECT_URI=https://your-domain/api/auth/gitlab/callback

# Frontend origin (used for OAuth redirect back to the browser)
FRONTEND_URL=https://your-domain
