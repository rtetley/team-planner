# TeamTree — production environment
# Copy to <server-dir>/.env.production on the VM and fill in all values.
# Never commit this file with real secrets.

NODE_ENV=production

# Port the Node.js server listens on (must match --api-port in deploy.sh)
PORT=3001

# Valkey / Redis connection URL
#
# Format: redis://[:<password>@]<host>:<port>[/<db-index>]
#
# Common setups:
#   Local Valkey/Redis (default, no auth):  redis://127.0.0.1:6379
#   Local with password:                    redis://:yourpassword@127.0.0.1:6379
#   Remote instance:                        redis://:yourpassword@my-redis-host:6379
#   Unix socket:                            redis+unix:///var/run/valkey/valkey.sock
#
# If you are running Valkey on the same VM as the server (recommended),
# install it with:
#   sudo apt-get install valkey   # Debian/Ubuntu 24.04+
#   sudo apt-get install redis    # older Debian/Ubuntu
# then check the socket/port with:
#   sudo systemctl status valkey  (or redis)
#   sudo valkey-cli ping          (or redis-cli ping)
#
# The default port is 6379 and no password is set out of the box,
# so the default URL below works for a local install with no auth.
VALKEY_URL=redis://127.0.0.1:6379

# GitLab OAuth — fill in to enable GitLab sign-in
GITLAB_URL=https://gitlab.com
GITLAB_CLIENT_ID=your-gitlab-application-id
GITLAB_CLIENT_SECRET=your-gitlab-application-secret
GITLAB_REDIRECT_URI=https://your-domain/api/auth/gitlab/callback

# Frontend origin (used for OAuth redirect back to the browser)
FRONTEND_URL=https://your-domain
