# TeamTree — development environment
# Copy to server/.env.development (or server/.env if NODE_ENV is unset)
# This file is safe to commit; it uses only local defaults.

NODE_ENV=development

# Port the Node.js server listens on
PORT=3001

# Local Valkey / Redis
VALKEY_URL=redis://127.0.0.1:6379

# GitLab OAuth — leave blank to disable GitLab sign-in locally
GITLAB_URL=https://gitlab.com
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:3001/api/auth/gitlab/callback

# Frontend origin (used for OAuth redirect back to the browser)
FRONTEND_URL=http://localhost:5173
